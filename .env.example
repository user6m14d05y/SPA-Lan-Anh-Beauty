# Copy file này thành .env và điền giá trị thật vào
# cp .env.example .env

# === SERVER ===
PORT=5000

# === DATABASE ===
MYSQL_ROOT_PASSWORD=your_root_password_here
DB_HOST=localhost
DB_PORT=3307
DB_NAME=spa_lananh
DB_USER=spa_user
DB_PASS=your_db_password_here

# === JWT ===
JWT_SECRET=your_jwt_secret_at_least_32_chars_long

# === SMTP EMAIL ===
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Lan Anh Beauty <no-reply@lananhbeauty.vn>"


# DOCKER COMPOSE

# TinyMCE API Key ( dep Wordpress )
VITE_TINY_MCE_API_KEY=your_tinymce_api_key

